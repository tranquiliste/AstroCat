    },
    "description": {
      "text": "LBN 1055 ist ein Emissionsnebel im suedlichen Herkules in etwa 5000 Lj Entfernung, Richtung Uebergang Herkules-Ophiuchus. Sommerziel mit Ha.",
      "source_hash": "sha256:a03a99c3d466fb1410d774f2266bad63a7088428e5873e5e66ba1229ca5c8dad"
    }
  },
  "LBN 1060": {
